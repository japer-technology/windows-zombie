#!/usr/bin/env bash
# health-check — one-shot health summary for Ubuntu Zombie.
set -uo pipefail

ZOMBIE_DIR="${ZOMBIE_DIR:-/opt/ai-zombie}"
SECRETS_FILE="${ZOMBIE_DIR}/secrets/env"

if [[ -t 1 ]]; then
  C_RESET=$'\033[0m'; C_RED=$'\033[31m'; C_GREEN=$'\033[32m'
  C_YEL=$'\033[33m'; C_BOLD=$'\033[1m'
else
  C_RESET=""; C_RED=""; C_GREEN=""; C_YEL=""; C_BOLD=""
fi

PASS=0; FAIL=0; WARN=0
check_ok()   { printf '  %s[ok]%s   %s\n' "${C_GREEN}" "${C_RESET}" "$*"; PASS=$((PASS+1)); }
check_warn() { printf '  %s[warn]%s %s\n' "${C_YEL}"   "${C_RESET}" "$*"; WARN=$((WARN+1)); }
check_fail() { printf '  %s[--]%s   %s\n' "${C_RED}"   "${C_RESET}" "$*"; FAIL=$((FAIL+1)); }

printf '%s== ubuntu-zombie health ==%s\n\n' "${C_BOLD}" "${C_RESET}"

# Chat service
if systemctl is-active --quiet ubuntu-zombie-chat.service 2>/dev/null; then
  check_ok "chat service active"
else
  check_fail "chat service not active (sudo systemctl start ubuntu-zombie-chat)"
fi

# Tailscale
if command -v tailscale >/dev/null 2>&1; then
  if tailscale status >/dev/null 2>&1 && ! tailscale status 2>/dev/null | grep -q "Logged out"; then
    check_ok "tailscale logged in"
  else
    check_fail "tailscale logged out (sudo tailscale up)"
  fi
else
  check_ok "tailscale not installed (skipped)"
fi

# SSH
if systemctl is-active --quiet ssh 2>/dev/null; then
  check_ok "ssh service active"
else
  check_fail "ssh service not active"
fi

# Firewall
if command -v ufw >/dev/null 2>&1 && sudo -n ufw status 2>/dev/null | grep -q "Status: active"; then
  check_ok "ufw active"
elif ufw status 2>/dev/null | grep -q "Status: active"; then
  check_ok "ufw active"
else
  check_warn "ufw status unknown (need root to query)"
fi

# Docker
if docker version >/dev/null 2>&1; then
  check_ok "docker reachable"
else
  check_warn "docker not reachable (log out/in so the docker group applies)"
fi

# Desktop / display
if [[ -n "${DISPLAY:-}" ]]; then
  # FIX-3-22: distinguish "gui-env helper missing" (installer never
  # ran / payload only) from "helper present but xdotool failed" so
  # the operator gets a useful pointer instead of a misleading
  # xdotool message.
  if [[ ! -x "${ZOMBIE_DIR}/bin/gui-env" ]]; then
    check_warn "gui-env helper missing at ${ZOMBIE_DIR}/bin/gui-env (re-run scripts/install.sh)"
  elif "${ZOMBIE_DIR}/bin/gui-env" xdotool getdisplaygeometry >/dev/null 2>&1; then
    check_ok "desktop reachable on ${DISPLAY}"
  else
    check_warn "DISPLAY=${DISPLAY} but xdotool failed (desktop session may not be live)"
  fi
else
  check_warn "DISPLAY not set (desktop helpers unavailable in this shell)"
fi

# Provider token presence (without reading the value)
if [[ -r "${SECRETS_FILE}" ]]; then
  if grep -Eq '^[[:space:]]*(export[[:space:]]+)?(OPENAI|ANTHROPIC)_API_KEY[[:space:]]*=[[:space:]]*.+' "${SECRETS_FILE}" 2>/dev/null; then
    check_ok "provider token present in secrets/env"
  else
    check_warn "no provider token in secrets/env (sudo ${ZOMBIE_DIR}/bin/secrets-edit)"
  fi
  PERMS="$(stat -c %a "${SECRETS_FILE}" 2>/dev/null || echo 000)"
  if [[ "${PERMS}" == "600" ]]; then
    check_ok "secrets/env permissions 600"
  else
    check_fail "secrets/env permissions ${PERMS} (must be 600)"
  fi
else
  check_warn "cannot read ${SECRETS_FILE} (this is expected for non-agent users)"
fi

# Disk space
AVAIL_KB="$(df -P / | awk 'NR==2 {print $4}')"
if [[ "${AVAIL_KB:-0}" -gt 2000000 ]]; then
  check_ok "free disk space $((AVAIL_KB/1024)) MB"
elif [[ "${AVAIL_KB:-0}" -gt 500000 ]]; then
  check_warn "low free disk space $((AVAIL_KB/1024)) MB"
else
  check_fail "very low free disk space $((AVAIL_KB/1024)) MB"
fi

# Audit log
AUDIT_LOG="/var/log/ubuntu-zombie/audit.log"
if [[ -f "${AUDIT_LOG}" ]]; then
  check_ok "audit log present ($(wc -l < "${AUDIT_LOG}") entries)"
else
  check_warn "audit log missing (will appear on first chat use)"
fi

echo
printf '%sResult:%s %d ok, %d warn, %d fail\n' "${C_BOLD}" "${C_RESET}" "${PASS}" "${WARN}" "${FAIL}"
if [[ "${FAIL}" -gt 0 ]]; then exit 1; fi
