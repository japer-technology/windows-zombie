#!/usr/bin/env bash
#
# setup-agent-venv
# ----------------
# Provision the unprivileged Python virtualenv for the Ubuntu Zombie
# agent account (default `~/agent-env`) and download the Chromium browser
# binaries for Playwright.
#
# Run as the AGENT_USER (not root):
#   runuser -l "${AGENT_USER}" -- "${ZOMBIE_DIR}/bin/setup-agent-venv"
#
# This script is intentionally idempotent and retries transient pip /
# Playwright failures with exponential backoff. The matching apt-level
# Chromium system dependencies are installed separately by install.sh
# (as root), because `playwright install --with-deps` shells out to
# apt-get and would fail unprivileged. See FIX-1-01 and FIX-1-12.

set -Eeuo pipefail

VENV_DIR="${VENV_DIR:-${HOME}/agent-env}"

if [[ ! -d "${VENV_DIR}" ]]; then
  python3 -m venv "${VENV_DIR}"
fi

# shellcheck disable=SC1091
. "${VENV_DIR}/bin/activate"

pip_with_retry() {
  local n=1 delay=3
  while true; do
    if pip "$@"; then return 0; fi
    if (( n >= 4 )); then return 1; fi
    echo "pip retry ${n} in ${delay}s..."
    sleep "${delay}"
    n=$((n + 1)); delay=$((delay * 2))
  done
}

pip_with_retry install --upgrade pip wheel setuptools
# Phase 1 (UPGRADE-TO-PI-PLAN §4.1): the bespoke openai/anthropic
# Python clients are gone. Provider calls go through the Node
# @earendil-works/pi-ai library via payload/agent/pi-ai-bridge.mjs.
# The Python venv still ships the broader operator toolkit (requests,
# pyautogui, playwright, …) used by helpers outside the chat loop.
pip_with_retry install --upgrade \
  requests \
  pydantic \
  rich \
  typer \
  python-dotenv \
  playwright \
  pyautogui \
  pillow \
  mss \
  opencv-python \
  python-xlib

# Playwright browser downloads tend to flake on transient network. The
# matching apt-level Chromium deps are installed as root before this
# script runs, so we only need the unprivileged browser fetch here.
n=1; delay=5
while true; do
  if python -m playwright install chromium; then break; fi
  if (( n >= 4 )); then
    echo "playwright install failed after ${n} attempts; rerun later." >&2
    # FIX-3-04: signal failure so callers (install.sh) can detect the
    # broken browser install instead of falling off the end with the
    # echo's exit status (0).
    mkdir -p "${HOME}/.cache/ubuntu-zombie"
    : > "${HOME}/.cache/ubuntu-zombie/playwright-failed"
    exit 1
  fi
  echo "playwright retry ${n} in ${delay}s..."
  sleep "${delay}"
  n=$((n + 1)); delay=$((delay * 2))
done

# FIX-3-04: clear the failure sentinel on success so the next health
# check stops complaining once the operator has fixed the network.
rm -f "${HOME}/.cache/ubuntu-zombie/playwright-failed" 2>/dev/null || true
