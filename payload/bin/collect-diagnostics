#!/usr/bin/env bash
# collect-diagnostics — bundle logs and state for a bug report.
# Secrets are redacted before write.
set -euo pipefail

OUT_DIR="${TMPDIR:-/tmp}"
STAMP="$(date -u +%Y%m%d-%H%M%S)"
BUNDLE_DIR="$(mktemp -d "${OUT_DIR}/ubuntu-zombie-diagnostics-${STAMP}.XXXX")"
TARBALL="${OUT_DIR}/ubuntu-zombie-diagnostics-${STAMP}.tar.gz"

# FIX-3-23: clean up the staging directory on every exit path (tar
# failure, signal, success), not just when the explicit `rm -rf` at
# the bottom is reached.
trap 'rm -rf "${BUNDLE_DIR}"' EXIT

redact() {
  # Strip token-shaped values from stdin to stdout.
  sed -E \
    -e 's/sk-[A-Za-z0-9_-]{12,}/sk-***REDACTED***/g' \
    -e 's/sk-ant-[A-Za-z0-9_-]{12,}/sk-ant-***REDACTED***/g' \
    -e 's/tskey-[A-Za-z0-9_-]{12,}/tskey-***REDACTED***/g' \
    -e 's/(ssh-(rsa|ed25519|dss)) [A-Za-z0-9+/=]{20,}( ?.*)?/\1 ***REDACTED***/g' \
    -e 's/((API[_-]?KEY|TOKEN|PASSWORD|SECRET)([[:space:]]*[:=][[:space:]]*))[^[:space:]]+/\1***REDACTED***/Ig'
}

capture() {
  local name="$1"; shift
  { echo "## $* (saved $(date -u +%FT%TZ))"; "$@" 2>&1; } | redact > "${BUNDLE_DIR}/${name}"
}

echo "Collecting diagnostics into ${BUNDLE_DIR}/ ..."

capture os-release.txt          cat /etc/os-release
capture uname.txt               uname -a
capture lsb-release.txt         lsb_release -a
capture df.txt                  df -h
capture free.txt                free -h
capture systemctl-failed.txt    systemctl --failed --no-pager
capture systemctl-zombie.txt    systemctl status ubuntu-zombie-chat.service ubuntu-zombie-health.timer --no-pager
capture journal-zombie.txt      journalctl -u ubuntu-zombie-chat.service -n 400 --no-pager
capture journal-tailscaled.txt  journalctl -u tailscaled -n 200 --no-pager
capture tailscale-status.txt    tailscale status
capture ufw-status.txt          sh -c 'sudo -n ufw status verbose 2>&1 || ufw status verbose'
capture docker-version.txt      docker version
capture docker-info.txt         docker info
capture verify.txt              /opt/ai-zombie/bin/verify
capture health.txt              /opt/ai-zombie/bin/health-check

# Installer log
if [[ -r /var/log/ubuntu-zombie-install.log ]]; then
  redact < /var/log/ubuntu-zombie-install.log > "${BUNDLE_DIR}/install.log"
fi

# Audit log (already redacted at write, but redact again defensively)
if [[ -r /var/log/ubuntu-zombie/audit.log ]]; then
  redact < /var/log/ubuntu-zombie/audit.log > "${BUNDLE_DIR}/audit.log"
fi

# Policy (no secrets in policy file by design)
if [[ -r /etc/ubuntu-zombie/policy.yaml ]]; then
  cp /etc/ubuntu-zombie/policy.yaml "${BUNDLE_DIR}/policy.yaml"
fi

# Package versions
{
  echo "## dpkg core packages"
  dpkg -l docker-ce docker-ce-cli containerd.io tailscale openssh-server \
         python3 nodejs gdm3 x11vnc xdotool ufw 2>&1 || true
} | redact > "${BUNDLE_DIR}/packages.txt"

tar -czf "${TARBALL}" -C "$(dirname "${BUNDLE_DIR}")" "$(basename "${BUNDLE_DIR}")"
# FIX-3-23: the EXIT trap removes BUNDLE_DIR; no explicit rm here.

echo
echo "Diagnostic bundle: ${TARBALL}"
echo "Secrets have been redacted, but please review before sharing."
